{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mattjoyce/ductile/schemas/pipelines.schema.json",
  "title": "Ductile Pipelines",
  "description": "Schema for ductile pipelines.yaml — defines event-driven pipeline orchestration.",
  "type": "object",
  "properties": {
    "pipelines": {
      "type": "array",
      "description": "List of pipeline definitions.",
      "items": { "$ref": "#/$defs/PipelineEntry" }
    }
  },
  "required": ["pipelines"],
  "additionalProperties": false,
  "$defs": {
    "PipelineEntry": {
      "type": "object",
      "description": "A named pipeline triggered by an event type.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique pipeline name.",
          "minLength": 1
        },
        "on": {
          "type": "string",
          "description": "Event type that triggers this pipeline (mutually exclusive with on-hook).",
          "minLength": 1
        },
        "on-hook": {
          "type": "string",
          "description": "Lifecycle signal that triggers this pipeline (mutually exclusive with on).",
          "enum": ["job.completed", "job.failed", "job.timed_out"]
        },
        "from_plugin": {
          "type": "string",
          "description": "Optional source-plugin selector. When set, the trigger or hook signal only matches when the upstream plugin is exactly this plugin. Empty means today's behaviour — match regardless of source plugin.",
          "minLength": 1
        },
        "if": {
          "$ref": "#/$defs/Condition",
          "description": "Optional pipeline-level trigger predicate. Evaluated against payload + upstream durable context after trigger/hook name match; a false result skips dispatch entirely."
        },
        "max_depth": {
          "type": "integer",
          "description": "Optional author-set route depth cap. Overrides the auto-computed cap. 0 means unlimited.",
          "minimum": 0
        },
        "steps": {
          "type": "array",
          "description": "Ordered steps in the pipeline.",
          "items": { "$ref": "#/$defs/StepEntry" }
        },
        "execution_mode": {
          "type": "string",
          "description": "How the pipeline is triggered and results returned.",
          "enum": ["async", "synchronous"],
          "default": "async"
        },
        "timeout": {
          "type": "string",
          "description": "Maximum duration for synchronous pipeline execution (Go duration).",
          "pattern": "^[0-9]+(ns|us|µs|ms|s|m|h)+$"
        }
      },
      "required": ["name"],
      "oneOf": [
        { "required": ["on"], "not": { "required": ["on-hook"] } },
        { "required": ["on-hook"], "not": { "required": ["on"] } }
      ],
      "additionalProperties": false
    },
    "Condition": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "op": {
          "type": "string",
          "enum": ["exists", "eq", "neq", "in", "gt", "gte", "lt", "lte", "contains", "startswith", "endswith", "regex"]
        },
        "value": {},
        "all": {
          "type": "array",
          "items": { "$ref": "#/$defs/Condition" }
        },
        "any": {
          "type": "array",
          "items": { "$ref": "#/$defs/Condition" }
        },
        "not": {
          "$ref": "#/$defs/Condition"
        }
      },
      "additionalProperties": false
    },
    "StepEntry": {
      "type": "object",
      "description": "A single step in a pipeline.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Step identifier (auto-generated if omitted)."
        },
        "uses": {
          "type": "string",
          "description": "Plugin name to invoke for this step."
        },
        "call": {
          "type": "string",
          "description": "Inline call expression (alternative to uses)."
        },
        "relay": {
          "$ref": "#/$defs/RelayStep",
          "description": "First-class remote event relay step."
        },
        "if": {
          "$ref": "#/$defs/Condition",
          "description": "Optional structured condition controlling whether the step runs."
        },
        "steps": {
          "type": "array",
          "description": "Nested sequential sub-steps.",
          "items": { "$ref": "#/$defs/StepEntry" }
        },
        "split": {
          "type": "array",
          "description": "Parallel fan-out sub-steps.",
          "items": { "$ref": "#/$defs/StepEntry" }
        },
        "with": {
          "type": "object",
          "description": "Optional payload remap for a uses step. Values are templates resolved from payload.* or context.* before the plugin is spawned.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "baggage": {
          "$ref": "#/$defs/BaggageSpec",
          "description": "Optional durable context claims for a uses step. Mappings name durable facts explicitly; bulk import requires a namespace until plugin manifest defaults are available."
        }
      },
      "additionalProperties": false,
      "oneOf": [
        {
          "required": ["uses"],
          "not": {
            "anyOf": [
              { "required": ["call"] },
              { "required": ["relay"] },
              { "required": ["steps"] },
              { "required": ["split"] }
            ]
          }
        },
        {
          "required": ["call"],
          "not": {
            "anyOf": [
              { "required": ["uses"] },
              { "required": ["relay"] },
              { "required": ["steps"] },
              { "required": ["split"] },
              { "required": ["with"] },
              { "required": ["baggage"] }
            ]
          }
        },
        {
          "required": ["relay"],
          "not": {
            "anyOf": [
              { "required": ["uses"] },
              { "required": ["call"] },
              { "required": ["steps"] },
              { "required": ["split"] },
              { "required": ["with"] },
              { "required": ["baggage"] }
            ]
          }
        },
        {
          "required": ["steps"],
          "not": {
            "anyOf": [
              { "required": ["uses"] },
              { "required": ["call"] },
              { "required": ["relay"] },
              { "required": ["split"] },
              { "required": ["with"] },
              { "required": ["baggage"] }
            ]
          }
        },
        {
          "required": ["split"],
          "not": {
            "anyOf": [
              { "required": ["uses"] },
              { "required": ["call"] },
              { "required": ["relay"] },
              { "required": ["steps"] },
              { "required": ["with"] },
              { "required": ["baggage"] }
            ]
          }
        }
      ]
    },
    "RelayStep": {
      "type": "object",
      "description": "Remote Event Relay step. Trust material and URLs remain in relay-instances.yaml.",
      "properties": {
        "to": {
          "type": "string",
          "description": "Named outbound relay instance.",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "event": {
          "type": "string",
          "description": "Remote event type to deliver.",
          "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        },
        "dedupe_key": {
          "type": "string",
          "description": "Optional expression for the remote event dedupe_key."
        },
        "with": {
          "type": "object",
          "description": "Remote event payload projection. Values are expressions resolved from payload.* or context.*.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "baggage": {
          "$ref": "#/$defs/BaggageSpec",
          "description": "Optional explicit baggage projection into the relay envelope."
        }
      },
      "required": ["to", "event"],
      "additionalProperties": false
    },
    "BaggageSpec": {
      "type": "object",
      "description": "Durable context claims for a pipeline uses step. Each mapping key is a durable dotted path and each value is a source expression such as payload.text or context.origin.channel. The special from/namespace pair imports an object under an explicit namespace.",
      "properties": {
        "from": {
          "type": "string",
          "description": "Bulk import source. Must reference payload or payload.<path>.",
          "pattern": "^payload(\\.[A-Za-z_][A-Za-z0-9_]*)*$",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "description": "Durable namespace for a bulk import. Required at runtime when from is set until plugin manifest defaults are available.",
          "$ref": "#/$defs/DottedPath"
        }
      },
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*$": {
          "type": "string",
          "description": "Source expression for an explicitly named durable fact.",
          "minLength": 1
        }
      },
      "dependentRequired": {
        "namespace": ["from"]
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "DottedPath": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*$",
      "minLength": 1
    }
  }
}
