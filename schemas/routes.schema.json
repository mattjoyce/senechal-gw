{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mattjoyce/ductile/schemas/routes.schema.json",
  "title": "Ductile Routes",
  "description": "Schema for ductile routes.yaml — legacy event routing rules.",
  "type": "object",
  "properties": {
    "routes": {
      "type": "array",
      "description": "List of event routing rules.",
      "items": {
        "$ref": "config.schema.json#/$defs/RouteConfig"
      }
    }
  },
  "required": ["routes"],
  "additionalProperties": false
}
