{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mattjoyce/ductile/schemas/include.schema.json",
  "title": "Ductile Include File",
  "description": "Schema for any ductile YAML file loaded via the 'include' mechanism. All top-level keys are optional because included files are deep-merged into the root config. An included file may contain any subset of config keys, and may itself include further files.",
  "type": "object",
  "properties": {
    "include": {
      "type": "array",
      "description": "Further files to merge (recursive includes).",
      "items": { "type": "string" }
    },
    "environment_vars": {
      "$ref": "config.schema.json#/$defs/EnvironmentVarsConfig"
    },
    "service": {
      "$ref": "config.schema.json#/$defs/ServiceConfig"
    },
    "state": {
      "$ref": "config.schema.json#/$defs/StateConfig"
    },
    "database": {
      "$ref": "config.schema.json#/$defs/StateConfig"
    },
    "api": {
      "$ref": "config.schema.json#/$defs/APIConfig"
    },
    "plugin_roots": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "plugins": {
      "type": "object",
      "additionalProperties": {
        "$ref": "config.schema.json#/$defs/PluginConf"
      }
    },
    "instances": {
      "type": "array",
      "items": { "$ref": "config.schema.json#/$defs/RelayInstanceConfig" }
    },
    "remote_ingress": {
      "$ref": "config.schema.json#/$defs/RemoteIngressConfig"
    },
    "routes": {
      "type": "array",
      "items": { "$ref": "config.schema.json#/$defs/RouteConfig" }
    },
    "webhooks": {
      "$ref": "config.schema.json#/$defs/WebhooksConfig"
    },
    "pipelines": {
      "type": "array",
      "items": { "$ref": "pipelines.schema.json#/$defs/PipelineEntry" }
    },
    "tokens": {
      "type": "array",
      "description": "Token entries (when file is tokens.yaml).",
      "items": {
        "$ref": "tokens.schema.json#/properties/tokens/items"
      }
    }
  },
  "additionalProperties": false
}
