{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mattjoyce/ductile/schemas/webhooks.schema.json",
  "title": "Ductile Webhooks",
  "description": "Schema for ductile webhooks.yaml — standalone webhook endpoint definitions (directory mode).",
  "type": "object",
  "properties": {
    "webhooks": {
      "type": "array",
      "description": "List of webhook endpoints.",
      "items": {
        "$ref": "config.schema.json#/$defs/WebhookEndpoint"
      }
    }
  },
  "required": ["webhooks"],
  "additionalProperties": false
}
